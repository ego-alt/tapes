# Standalone dev needs none of these — defaults work (MUSIC_DIR=./music,
# send_file streaming, an implicit local user).

# Required behind the dashboard (Stage 2):
# SECRET_KEY=            # python -c "import secrets; print(secrets.token_hex(32))"
# APPLICATION_ROOT=/music
# AUTH_PROXY_HEADER=X-Forwarded-User
# MUSIC_DIR=/data/music
# USE_X_ACCEL=1

# Standalone overrides:
# MUSIC_DIR=/absolute/path/to/mp3s
# MUSIC_LOCAL_USER=local
